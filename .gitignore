# ============================================================
# .gitignore — Archivos que Git debe ignorar
# ============================================================

# Variables de entorno (contiene la API key — NUNCA subir)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Dependencias de Node.js
node_modules/

# Archivos de Vercel
.vercel/

# Archivos del sistema operativo
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Archivos de editores
.vscode/
.idea/
.vercel
